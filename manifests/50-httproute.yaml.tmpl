apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: __RELEASE_NAME__-http
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: gitlab
    app.kubernetes.io/instance: __RELEASE_NAME__
    app.kubernetes.io/managed-by: archinfra-installer
spec:
  parentRefs:
    - name: __GATEWAY_NAME__
      namespace: __GATEWAY_NAMESPACE__
      sectionName: __GATEWAY_HTTP_SECTION__
  hostnames:
    - __HOSTNAME__
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: __RELEASE_NAME__
          port: 80
